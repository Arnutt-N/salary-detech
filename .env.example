# ─── Database ───
# Local SQLite (development without Docker — default for `npm run dev`)
DATABASE_URL="file:./dev.db"

# Turso / libSQL (production, or local dev with Docker)
# Start local Turso: docker compose up -d
# Then set: TURSO_DATABASE_URL="libsql://localhost:8080"
# For production Turso Cloud, get the URL from turso.tech dashboard
TURSO_DATABASE_URL="libsql://your-db.turso.io"

# Prisma CLI uses DATABASE_URL for schema pushes. At runtime, lib/prisma.ts
# prefers TURSO_DATABASE_URL and falls back to DATABASE_URL.

# ─── Auth.js ───
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_TRUST_HOST="true"

# ─── Admin Credentials ───
# Used by lib/auth.ts for login. NEVER hardcode in code.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_ME_IN_PRODUCTION"

# ─── Cron Secret ───
# Vercel Cron: Settings → Environment Variables → CRON_SECRET
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here"

# ─── Deployment ───
# Vercel: set these env vars in the Vercel dashboard (Settings → Environment Variables)
# 1. DATABASE_URL (if using Prisma CLI for migrations in CI)
# 2. TURSO_DATABASE_URL (runtime connection — libsql://...)
# 3. AUTH_SECRET
# 4. NODE_VERSION=20

# ─── Optional ───
# SENTRY_DSN= (error tracking — P5)
